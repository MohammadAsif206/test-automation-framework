# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://www.saucedemo.com

# ── Engine: selenium | playwright ────────────────────────────────────────────
DRIVER=selenium

# ── Browser: chrome | firefox | edge  (selenium)
#            chromium | firefox | webkit  (playwright)
BROWSER=chrome

# ── Modes ─────────────────────────────────────────────────────────────────────
HEADLESS=true
INCOGNITO=true

# ── Selenium Grid (leave empty for local) ────────────────────────────────────
GRID_URL=

# ── Edge driver (only needed if BROWSER=edge on restricted networks) ─────────
# Download from: https://developer.microsoft.com/en-us/microsoft-edge/tools/webdriver
# Match version to your Edge browser (check edge://settings/help)
EDGE_DRIVER_PATH=

# ── Timeouts ──────────────────────────────────────────────────────────────────
DEFAULT_TIMEOUT=15000
IMPLICIT_WAIT=10
SLOW_MO=0

# ── Credentials ───────────────────────────────────────────────────────────────
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce
